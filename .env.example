# ==== MySQL (Docker Instance) ====
MYSQL_DATABASE=freeedu
MYSQL_USER=freeedu
MYSQL_PASSWORD=freeedu_pass
MYSQL_ROOT_PASSWORD=root_pass

# ==== Backend / Core ====
SPRING_PROFILES_ACTIVE=docker
BACKEND_PORT=8080

# ==== Frontend (dev proxy) ====
FRONTEND_PORT=5173
FRONTEND_BASE_URL=http://localhost:5173,http://localhost:5174
VITE_API_BASE_URL=http://localhost:8080
BACKEND_URL=http://backend:8080
JWT_SECRET_KEY=YTM0NWU2Nzg5MGFiY2RlZmdoaWprbG1ub3BxcnN0dXZ3eHl6MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:80

# ==== Password Reset / Mail ====
PASSWORD_RESET_EXPIRATION_MINUTES=30
# MAIL_ENABLED=false is intended only for local/dev/test usage.
# In production MAIL_ENABLED should be true.
# When false, password reset still returns success, but no real email will be sent.
MAIL_ENABLED=false
MAIL_FROM_ADDRESS=no-reply@freeedu.local
MAIL_FROM_NAME=FreeEdu
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

# ==== STT Service ====
STT_PORT=8000
STT_MODEL_SIZE=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
STT_MIN_SCORE=0.85
