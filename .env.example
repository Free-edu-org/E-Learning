# ==== MySQL (Docker Instance) ====
MYSQL_DATABASE=freeedu
MYSQL_USER=freeedu
MYSQL_PASSWORD=freeedu_pass
MYSQL_ROOT_PASSWORD=root_pass

# ==== Backend / Core ====
SPRING_PROFILES_ACTIVE=docker
BACKEND_PORT=8080

# ==== Frontend (dev proxy) ====
FRONTEND_PORT=5173

# ==== STT Service ====
STT_PORT=8000
STT_MODEL_SIZE=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
STT_MIN_SCORE=0.85
