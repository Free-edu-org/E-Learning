### Get all tasks for a lesson (STUDENT/TEACHER/ADMIN)
GET http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks
Authorization: Bearer {{auth_token}}

### Create choose task (ADMIN or lesson owner TEACHER)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "What is 2+2?",
  "possibleAnswers": "3|4|5|6",
  "correctAnswer": 1,
  "hint": "Basic math",
  "section": "Math"
}

### Update choose task
PUT http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose/{{task_public_id}}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "What is 3+3?",
  "possibleAnswers": "5|6|7|8",
  "correctAnswer": 1,
  "hint": "Updated",
  "section": "Math"
}

### Delete choose task
DELETE http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose/{{task_public_id}}
Authorization: Bearer {{auth_token}}

### Create write task
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/write
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "Write the past tense of 'go'",
  "correctAnswer": "went",
  "hint": "Irregular verb",
  "section": "Grammar"
}

### Update write task
PUT http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/write/{{task_public_id}}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "Write the past tense of 'run'",
  "correctAnswer": "ran",
  "hint": "Also irregular",
  "section": "Grammar"
}

### Delete write task
DELETE http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/write/{{task_public_id}}
Authorization: Bearer {{auth_token}}

### Create scatter task
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/scatter
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "Arrange the words",
  "words": "is|cat|the|big",
  "correctAnswer": "the cat is big",
  "hint": "Subject first",
  "section": "Grammar"
}

### Update scatter task
PUT http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/scatter/{{task_public_id}}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "Arrange updated",
  "words": "is|dog|the|small",
  "correctAnswer": "the dog is small",
  "hint": "Subject first"
}

### Delete scatter task
DELETE http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/scatter/{{task_public_id}}
Authorization: Bearer {{auth_token}}

### Create speak task
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/speak
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "Say hello in English",
  "expectedText": "Hello",
  "hint": "Greeting",
  "section": "Speaking"
}

### Update speak task
PUT http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/speak/{{task_public_id}}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "Say goodbye in English",
  "expectedText": "Goodbye",
  "hint": "Farewell"
}

### Transcribe speak task audio (STUDENT only)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/speak/{{task_public_id}}/transcribe
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=FreeEduBoundary

--FreeEduBoundary
Content-Disposition: form-data; name="file"; filename="answer.webm"
Content-Type: audio/webm

< ./answer.webm
--FreeEduBoundary--

### Delete speak task
DELETE http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/speak/{{task_public_id}}
Authorization: Bearer {{auth_token}}

### Submit lesson answers (STUDENT only)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/submit
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "answers": [
    { "taskPublicId": "{{task_public_id}}", "taskType": "choose", "answer": "1" },
    { "taskPublicId": "{{task_public_id}}", "taskType": "write", "answer": "went" },
    { "taskPublicId": "{{task_public_id}}", "taskType": "speak", "answer": "Hello" }
  ]
}

### Reset user progress (ADMIN or lesson owner TEACHER)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/users/{{user_public_id}}/reset
Authorization: Bearer {{auth_token}}

### Upload hint image for a choose task (ADMIN or lesson owner TEACHER)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose/{{task_public_id}}/hint-image
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=----boundary

------boundary
Content-Disposition: form-data; name="file"; filename="hint.jpg"
Content-Type: image/jpeg

< ./hint.jpg
------boundary--

### Get hint image for a task (STUDENT/TEACHER/ADMIN)
GET http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose/{{task_public_id}}/hint-image
Authorization: Bearer {{auth_token}}

### Delete hint image for a task (ADMIN or lesson owner TEACHER)
DELETE http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose/{{task_public_id}}/hint-image
Authorization: Bearer {{auth_token}}

### Create choose task without auth (expect 401)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose
Content-Type: application/json

{
  "task": "No auth",
  "possibleAnswers": "a|b",
  "correctAnswer": 0
}

### Create choose task with invalid payload (expect 400)
POST http://localhost:8080/api/v1/lessons/{{lesson_public_id}}/tasks/choose
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "task": "",
  "possibleAnswers": "",
  "correctAnswer": null
}
