# ==== MySQL Connection ====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=freeedu
DB_USER=freeedu
DB_PASSWORD=freeedu_pass

# ==== Backend ====
SPRING_PROFILES_ACTIVE=local
BACKEND_PORT=8080

# ==== Security ====
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# ==== Password Reset ====
PASSWORD_RESET_EXPIRATION_MINUTES=30
FRONTEND_BASE_URL=http://localhost:5173

# ==== Mail ====
# MAIL_ENABLED=false is intended only for local/dev/test usage.
# In production MAIL_ENABLED should be true.
# When false, password reset still returns success, but no real email will be sent.
MAIL_ENABLED=false
MAIL_FROM_ADDRESS=no-reply@freeedu.local
MAIL_FROM_NAME=FreeEdu
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

# ==== Logging ====
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_FREEEDU=INFO
LOG_PATH=logs
LOG_FILE=freeedu.log
LOG_MAX_FILE_SIZE=50MB
LOG_MAX_HISTORY=14
LOG_TOTAL_SIZE_CAP=5GB
