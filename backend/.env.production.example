# ==== Backend Azure Production Example ====
SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8080

# Database with SSL
SPRING_DATASOURCE_URL=jdbc:mysql://[your-db-host]:3306/[db-name]?useSSL=true&requireSSL=true&verifyServerCertificate=false&serverTimezone=UTC

# JWT Security
JWT_SECRET_KEY=[your-base64-secret-min-32-chars]
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=https://[your-frontend-host].azurecontainerapps.io
